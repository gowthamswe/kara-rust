[0.003, "o", "enum OrderStatus {\r\n    Pending,\r\n    Shipped,\r\n    Delivered,\r\n    Cancelled,\r\n}\r\n\r\nfn describe(status: OrderStatus) -> String {\r\n    match status {\r\n        OrderStatus.Pending => \"awaiting payment\",\r\n        OrderStatus.Shipped => \"in transit\",\r\n        OrderStatus.Delivered => \"received by customer\",\r\n        OrderStatus.Cancelled => \"cancelled by customer or merchant\",\r\n    }\r\n}\r\n\r\nfn main() {\r\n    println(describe(OrderStatus.Shipped));\r\n}\r\n"]
